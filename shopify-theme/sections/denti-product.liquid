{%- assign p = product -%}
{%- assign v = p.selected_or_first_available_variant -%}
{%- assign disc = 0 -%}
{%- if p.compare_at_price > p.price -%}
  {%- assign disc = p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price -%}
{%- endif -%}
{%- assign img_demo = 'https://cdn.shopify.com/s/files/1/0835/7537/4043/files/hydropulseur_dentaire_video_480x480_46d501c2-3f62-495b-89b4-6b29d4ad33a6.webp?v=1782589693' -%}
{%- assign img_jet = 'https://cdn.shopify.com/s/files/1/0835/7537/4043/files/image-1782589498640.webp?v=1782589509' -%}
{%- assign img_ba = 'https://cdn.shopify.com/s/files/1/0835/7537/4043/files/ChatGPT_Image_27_juin_2026_21_46_43.png?v=1782589616' -%}

<section class="dlp" id="dlp-{{ section.id }}">
  <div class="dlp-announce">
    <span class="dlp-dot"></span> Offre de lancement{% if disc > 0 %} · −{{ disc }}%{% endif %} · Paiement à la livraison partout au Maroc
  </div>

  <div class="dlp-wrap">
    <nav class="dlp-crumb"><a href="{{ routes.root_url }}">Accueil</a> <span>›</span> <a href="{{ routes.all_products_collection_url }}">Boutique</a> <span>›</span> <b>{{ p.title }}</b></nav>

    <div class="dlp-top">
      <!-- GALLERY -->
      <div class="dlp-gallery">
        <div class="dlp-stage">
          {% if disc > 0 %}<span class="dlp-badge">−{{ disc }}%</span>{% endif %}
          {%- for media in p.media limit: 1 -%}
            <img id="dlp-main-{{ section.id }}" class="dlp-main" src="{{ media | image_url: width: 1200 }}" alt="{{ p.title | escape }}" width="700" height="700" loading="eager">
          {%- endfor -%}
        </div>
        {% if p.media.size > 1 %}
        <div class="dlp-thumbs">
          {%- for media in p.media limit: 8 -%}
            <button type="button" class="dlp-thumb{% if forloop.first %} is-active{% endif %}" data-full="{{ media | image_url: width: 1200 }}" aria-label="Image {{ forloop.index }}">
              <img src="{{ media | image_url: width: 200 }}" alt="" width="80" height="80" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
        {% endif %}
      </div>

      <!-- BUY BOX -->
      <div class="dlp-buy">
        <div class="dlp-eyebrow">Denti Luxe · Hydropulseur sans fil</div>
        <h1 class="dlp-title">{{ p.title }}</h1>
        <div class="dlp-stars-row"><span class="dlp-stars">★★★★★</span><span class="dlp-muted">4.9/5 · +1 200 clients satisfaits</span></div>

        <div class="dlp-price">
          <span class="dlp-now dlp-jnow">{{ p.price | money }}</span>
          {% if p.compare_at_price > p.price %}<span class="dlp-old dlp-jold">{{ p.compare_at_price | money }}</span>{% endif %}
          <span class="dlp-save dlp-jsave">{% if disc > 0 %}Économisez {{ p.compare_at_price | minus: p.price | money }}{% endif %}</span>
        </div>

        <p class="dlp-lead">Le jet d’eau pulsé qui nettoie en profondeur là où la brosse et le fil n’atteignent pas. Idéal pour <b>facettes, bridges &amp; gencives sensibles</b>.</p>

        <div class="dlp-chips">
          <span class="dlp-chip">3 modes de jet</span>
          <span class="dlp-chip">Étanche IPX7</span>
          <span class="dlp-chip">Recharge USB</span>
          <span class="dlp-chip">Sans fil</span>
        </div>

        <div class="dlp-packs" aria-label="Choisissez votre pack">
          {%- for variant in p.variants -%}
            {%- assign vsave = variant.compare_at_price | minus: variant.price -%}
            <button type="button" class="dlp-pack{% if forloop.index == 2 %} dlp-pack--pop{% endif %}{% if variant.id == v.id %} is-sel{% endif %}" data-vid="{{ variant.id }}" data-now="{{ variant.price | money }}" data-old="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}" data-save="{% if vsave > 0 %}Économisez {{ vsave | money }}{% endif %}">
              <span class="dlp-pack__radio"></span>
              <span class="dlp-pack__txt">
                <b class="dlp-pack__name">{{ variant.title }}</b>
                {% if forloop.index == 2 %}<em class="dlp-pack__tag">★ Le plus choisi</em>{% endif %}
                {% if vsave > 0 %}<span class="dlp-pack__save">Économisez {{ vsave | money }}</span>{% endif %}
              </span>
              <span class="dlp-pack__price"><b>{{ variant.price | money }}</b>{% if variant.compare_at_price > variant.price %}<s>{{ variant.compare_at_price | money }}</s>{% endif %}</span>
            </button>
          {%- endfor -%}
        </div>

        <div id="dlp-cod" class="dlp-codzone">
          <div class="dlp-codzone__t">Commandez · paiement à la livraison</div>
          {%- comment -%} Emplacement des blocs d'app (Packs / Offres de quantité Releasit). {%- endcomment -%}
          {%- for block in section.blocks -%}
            <div class="dlp-appblock" {{ block.shopify_attributes }}>{% render block %}</div>
          {%- endfor -%}
          {%- comment -%} Le formulaire COD Releasit (mode intégré) s'affiche dans cette zone. Le champ ci-dessous transmet la variante. {%- endcomment -%}
          {% form 'product', p, class: 'dlp-form' %}
            <input type="hidden" name="id" value="{{ v.id }}" class="dlp-vid">
            <input type="hidden" name="return_to" value="/checkout">
          {% endform %}
        </div>

        <div class="dlp-cod"><span class="dlp-check">✓</span> Vous payez <b>à la livraison</b> · aucune avance · livraison 24–72h</div>

        <div class="dlp-assur">
          <div class="dlp-assur__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h20v12H2zM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6"/></svg><span>Paiement à la livraison</span></div>
          <div class="dlp-assur__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h11v9H3zM14 9h4l3 3v3h-7zM7 18a2 2 0 1 0 .01 0M17 18a2 2 0 1 0 .01 0"/></svg><span>Livré partout au Maroc</span></div>
          <div class="dlp-assur__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg><span>Satisfait ou remboursé</span></div>
        </div>
      </div>
    </div>

    <!-- DEMO GIF -->
    <div class="dlp-demo dlp-rv">
      <h2 class="dlp-h2">Voyez-le en action</h2>
      <div class="dlp-demo__media"><img src="{{ img_demo }}" alt="Démonstration : le jet d’eau déloge la plaque entre les dents" loading="lazy" width="480" height="480"></div>
      <p class="dlp-demo__cap">Le jet pulsé déloge la plaque et les résidus entre les dents et sous la gencive.</p>
    </div>

    <!-- BENEFITS -->
    <h2 class="dlp-h2 dlp-rv">Pourquoi vous allez l’adopter</h2>
    <div class="dlp-grid">
      <div class="dlp-card dlp-rv"><svg class="dlp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l1.6 6.4L20 10l-6.4 1.6L12 18l-1.6-6.4L4 10l6.4-1.6z"/></svg><h3>Nettoyage en profondeur</h3><p>Atteint les zones inaccessibles à la brosse.</p></div>
      <div class="dlp-card dlp-rv"><svg class="dlp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><h3>Protège vos facettes</h3><p>Nettoie en douceur facettes, bridges &amp; implants.</p></div>
      <div class="dlp-card dlp-rv"><svg class="dlp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20M8 14s1.5 2 4 2 4-2 4-2M9 9v.01M15 9v.01"/></svg><h3>Gencives plus saines</h3><p>Réduit la plaque et la mauvaise haleine.</p></div>
      <div class="dlp-card dlp-rv"><svg class="dlp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9z"/></svg><h3>Sans fil &amp; étanche</h3><p>3 modes de jet · rechargeable USB · IPX7.</p></div>
    </div>

    {%- assign im_use = p.images[3] | default: p.featured_image -%}
    {%- assign im_modes = p.images[5] | default: p.featured_image -%}
    {%- assign im_acc = p.images[2] | default: p.featured_image -%}

    <!-- SHOWCASE (description visuelle) -->
    <div class="dlp-show">
      <div class="dlp-showrow dlp-rv">
        <div class="dlp-showimg dlp-showimg--wide"><img src="{{ img_jet }}" alt="Jet d’eau nettoyant entre les dents — gros plan" loading="lazy" width="820" height="547"></div>
        <div class="dlp-showtxt">
          <div class="dlp-eyebrow">Un nettoyage professionnel à la maison</div>
          <h3>Comme après un détartrage — chez vous</h3>
          <p>Le jet d’eau pulsé déloge la plaque et les résidus là où la brosse et le fil dentaire n’arrivent pas.</p>
          <ul class="dlp-ul"><li>Sensation de propreté immédiate</li><li>Haleine fraîche toute la journée</li><li>1 minute par jour suffit</li></ul>
        </div>
      </div>
      <div class="dlp-showrow dlp-showrow--rev dlp-rv">
        <div class="dlp-showimg"><img src="{{ im_modes | image_url: width: 820 }}" alt="3 modes de jet — Soft, Normal, Pulse" loading="lazy" width="410" height="410"></div>
        <div class="dlp-showtxt">
          <div class="dlp-eyebrow">3 modes de jet</div>
          <h3>Doux pour les gencives, puissant sur la plaque</h3>
          <p>Réglez l’intensité selon votre besoin : <b>Soft</b> pour gencives sensibles, <b>Normal</b> au quotidien, <b>Pulse</b> pour masser les gencives.</p>
          <ul class="dlp-ul"><li>Spécial facettes, bridges &amp; implants</li><li>Étanche IPX7 — utilisable sous la douche</li><li>Rechargeable USB · plusieurs jours d’autonomie</li></ul>
        </div>
      </div>
      <div class="dlp-showrow dlp-rv">
        <div class="dlp-showimg"><img src="{{ im_acc | image_url: width: 820 }}" alt="Embouts et accessoires inclus" loading="lazy" width="410" height="410"></div>
        <div class="dlp-showtxt">
          <div class="dlp-eyebrow">Tout inclus</div>
          <h3>Prêt à l’emploi dès la livraison</h3>
          <p>Vous recevez l’appareil, ses embouts interchangeables et le câble de recharge. Rien d’autre à acheter.</p>
          <ul class="dlp-ul"><li>Embouts pour toute la famille</li><li>Réservoir d’eau intégré</li><li>Compact — se glisse partout</li></ul>
        </div>
      </div>
    </div>

    <!-- AVANT / APRES -->
    <div class="dlp-ba dlp-rv">
      <h2 class="dlp-h2">Le résultat, en image</h2>
      <img class="dlp-ba__img" src="{{ img_ba }}" alt="Avant / Après : gencives enflammées vs gencives saines et dents propres" loading="lazy" width="1536" height="1024">
    </div>

    <!-- MID CTA -->
    <div class="dlp-mid dlp-rv">
      <div class="dlp-eyebrow">Offre de lancement{% if disc > 0 %} · −{{ disc }}%{% endif %}</div>
      <h3 class="dlp-mid__h">Payez à la livraison — zéro risque</h3>
      <p class="dlp-mid__p">💡 Économisez jusqu’à 198 DH en choisissant le Pack de 3</p>
      <a href="#dlp-cod" class="dlp-btn">Je commande maintenant</a>
      <div class="dlp-mid__re"><span class="dlp-check">✓</span> Livraison 24–72h partout au Maroc · Satisfait ou remboursé</div>
    </div>

    <!-- SPECS + DESCRIPTION -->
    <div class="dlp-split">
      <div class="dlp-specs dlp-rv">
        <h2 class="dlp-h2 dlp-h2--flush">Caractéristiques</h2>
        <table class="dlp-table">
          <tr><th>Type</th><td>Hydropulseur sans fil</td></tr>
          <tr><th>Modes de jet</th><td>3 (Soft · Normal · Pulse)</td></tr>
          <tr><th>Étanchéité</th><td>IPX7 (utilisable sous la douche)</td></tr>
          <tr><th>Recharge</th><td>USB</td></tr>
          <tr><th>Autonomie</th><td>Plusieurs jours par charge</td></tr>
          <tr><th>Idéal pour</th><td>Facettes · bridges · implants · gencives sensibles</td></tr>
          <tr><th>Dans la boîte</th><td>Appareil + embouts + câble de recharge</td></tr>
        </table>
      </div>
      <div class="dlp-desc dlp-rv">
        <h2 class="dlp-h2 dlp-h2--flush">Description</h2>
        <div class="dlp-rte">{{ p.description }}</div>
      </div>
    </div>

    <!-- REVIEWS -->
    <div class="dlp-rev-head dlp-rv"><h2 class="dlp-h2 dlp-h2--flush">Avis clients</h2><span class="dlp-stars">★★★★★ <span class="dlp-muted">4.9/5 · 127 avis</span></span></div>
    <p class="dlp-rev-sub dlp-rv">Photos envoyées par nos clientes après réception 📸 — paiement à la livraison.</p>
    <div class="dlp-reviews">
      {%- assign dlp_rvphotos = "https://cdn.shopify.com/s/files/1/0835/7537/4043/files/DF8956A8-EA97-4865-A536-0EA089A5D7A4.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/A7A78B1E-D5B5-4BBE-BE03-64E4AC8B6833.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/F710FDD2-3B19-4845-BAD0-F986566B7FF6.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/95F3CB46-35C9-455E-A6FA-C3CDAF6B942F.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/86613520-E4C8-4115-B5B2-77CC27DE0ED9.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/693027CA-10A8-4465-BC99-BE986EEFEF14.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/513D677A-7F41-4437-BD35-363ABFC741B6.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/CAAF98A4-F4C2-4E1B-A0FA-DB35E0BC2F64.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/B122DBFE-A6F5-4CEE-A5AA-2D5397FB49C2.png?v=1782784565 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/AC7C3B95-F821-40A1-83AD-B9311919853E.png?v=1782784566 https://cdn.shopify.com/s/files/1/0835/7537/4043/files/37C8C49A-23EE-4470-AEC6-77B91A05A11D.png?v=1782784565" | split: " " -%}
      {%- assign dlp_rvnames = "Salma · Casablanca|Hajar · Rabat|Yassine · Marrakech|Imane · Tanger|Khadija · Fès|Oussama · Agadir|Sara · Meknès|Nada · Casablanca|Fatima Zahra · Oujda|Mehdi · Kénitra|Amal · Tétouan" | split: "|" -%}
      {%- assign dlp_rvtexts = "« Résultat incroyable, mes gencives ne saignent plus 😍 »|« Wllah ma ndemt, l’haleine fraîche o lasnan n9iyin bzaf 🔥 »|« Livré en 48h, payé à la livraison. Nickel ! »|« Bsah wa3ra, kan7ess b détartrage mn 3and tbib 😁 »|« Parfait pour mes facettes, je recommande à 100% »|« Top, jat m3aha les embouts kamlin, t9der tkhdemha l3a2ila kamla 👌 »|« Sensation de propreté juste après. J’adore ✨ »|« Chrit pack de 3, kola wa7ed f darna 3ndo l’embout dyalo 👍 »|« Batterie qui tient longtemps, très facile à utiliser »|« Service au top, confirmaw m3aya f WhatsApp o wsel f l’we9t 🙏 »|« Ahssen chra dyali had l’3am, mreggla bzaf 💧 »" | split: "|" -%}
      {%- for ph in dlp_rvphotos -%}
        <figure class="dlp-rvcard dlp-rv">
          <button type="button" class="dlp-rvphoto" data-full="{{ ph }}" aria-label="Voir l’avis client en grand">
            <img src="{{ ph }}" loading="lazy" width="1170" height="2532" alt="Avis client vérifié Denti Luxe">
            <span class="dlp-rvphoto__badge">✓ Vérifié</span>
          </button>
          <figcaption class="dlp-rvcap">
            <div class="dlp-rvcap__top"><b>{{ dlp_rvnames[forloop.index0] }}</b><span class="dlp-rvstars">★★★★★</span></div>
            <p>{{ dlp_rvtexts[forloop.index0] }}</p>
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
    <div class="dlp-lb" id="dlp-lb-{{ section.id }}" aria-hidden="true">
      <button type="button" class="dlp-lb__x" aria-label="Fermer">×</button>
      <button type="button" class="dlp-lb__nav dlp-lb__prev" aria-label="Précédent">‹</button>
      <img src="" alt="Avis client Denti Luxe" class="dlp-lb__img">
      <button type="button" class="dlp-lb__nav dlp-lb__next" aria-label="Suivant">›</button>
    </div>

    <!-- FAQ -->
    <h2 class="dlp-h2 dlp-rv">Questions fréquentes</h2>
    <div class="dlp-faq dlp-rv">
      <details><summary>C’est compatible avec mes facettes / bridges ?<span class="dlp-chev">⌄</span></summary><p>Oui, c’est même recommandé : le jet d’eau nettoie en douceur autour des facettes, bridges et implants sans les abîmer.</p></details>
      <details><summary>Ça remplace le fil dentaire ?<span class="dlp-chev">⌄</span></summary><p>Oui, et c’est plus efficace et plus doux pour les gencives.</p></details>
      <details><summary>La batterie tient combien de temps ?<span class="dlp-chev">⌄</span></summary><p>Plusieurs jours d’utilisation par charge. Sans fil, étanche (IPX7), recharge USB.</p></details>
      <details><summary>Comment je paie ?<span class="dlp-chev">⌄</span></summary><p>Vous payez à la livraison (cash), une fois le colis reçu. Aucune avance.</p></details>
      <details><summary>Vous livrez où ?<span class="dlp-chev">⌄</span></summary><p>Partout au Maroc, en 24 à 72h selon votre ville.</p></details>
    </div>

    <!-- FINAL CTA -->
    <div class="dlp-final dlp-rv">
      <h2 class="dlp-final__h">Prêt à retrouver un sourire éclatant ?</h2>
      <p class="dlp-final__p">Commandez en 30 secondes · Paiement à la livraison · Satisfait ou remboursé.</p>
      <div class="dlp-final__price"><span class="dlp-now dlp-jnow">{{ p.price | money }}</span>{% if p.compare_at_price > p.price %}<span class="dlp-old dlp-jold">{{ p.compare_at_price | money }}</span>{% endif %}</div>
      <a href="#dlp-cod" class="dlp-btn">Je commande maintenant</a>
    </div>
  </div>

  <!-- STICKY MOBILE BAR -->
  <div class="dlp-sticky">
    <div class="dlp-sticky__p"><span class="dlp-now dlp-jnow">{{ p.price | money }}</span>{% if p.compare_at_price > p.price %}<span class="dlp-old dlp-jold">{{ p.compare_at_price | money }}</span>{% endif %}</div>
    <a href="#dlp-cod" class="dlp-btn dlp-sticky__f">Commander</a>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800;900&family=Playfair+Display:wght@600;700;800&display=swap');
  #dlp-{{ section.id }}{--nv:#0B1320;--nv2:#10182A;--nb:#26314B;--go:#CBAA6A;--gl:#E6D09A;--tx:#EEF1F6;--dm:#A7AFBF;--mt:#717B90;--gn:#33BA86;font-family:'DM Sans',system-ui,sans-serif;color:var(--tx);background:var(--nv);display:block;overflow:hidden;}
  #dlp-{{ section.id }} *{box-sizing:border-box;}
  #dlp-{{ section.id }} .dlp-wrap{max-width:1120px;margin:0 auto;padding:0 20px 70px;}
  #dlp-{{ section.id }} .dlp-muted{color:var(--dm);font-size:.82rem;font-weight:500;}
  #dlp-{{ section.id }} .dlp-stars{color:var(--go);letter-spacing:2px;}
  #dlp-{{ section.id }} .dlp-announce{background:linear-gradient(90deg,rgba(203,170,106,.18),rgba(203,170,106,.05));border-bottom:1px solid var(--nb);text-align:center;padding:10px 16px;font-size:.78rem;font-weight:600;color:var(--gl);display:flex;gap:8px;align-items:center;justify-content:center;}
  #dlp-{{ section.id }} .dlp-dot{width:7px;height:7px;border-radius:50%;background:var(--gn);box-shadow:0 0 0 4px rgba(51,186,134,.18);}
  #dlp-{{ section.id }} .dlp-crumb{font-size:.78rem;color:var(--mt);padding:18px 0 6px;}
  #dlp-{{ section.id }} .dlp-crumb a{color:var(--dm);text-decoration:none;}#dlp-{{ section.id }} .dlp-crumb b{color:var(--gl);font-weight:600;}#dlp-{{ section.id }} .dlp-crumb span{margin:0 6px;color:var(--nb);}

  #dlp-{{ section.id }} .dlp-top{display:grid;grid-template-columns:1.05fr 1fr;gap:40px;align-items:start;padding-top:14px;}
  #dlp-{{ section.id }} .dlp-gallery{position:sticky;top:18px;}
  #dlp-{{ section.id }} .dlp-stage{position:relative;border-radius:24px;overflow:hidden;border:1px solid var(--nb);background:radial-gradient(circle at 50% 30%,#1B263F,#0A1120);aspect-ratio:1/1;box-shadow:0 30px 70px rgba(0,0,0,.5);}
  #dlp-{{ section.id }} .dlp-main{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s;}
  #dlp-{{ section.id }} .dlp-stage:hover .dlp-main{transform:scale(1.06);}
  #dlp-{{ section.id }} .dlp-badge{position:absolute;top:14px;left:14px;z-index:2;background:linear-gradient(135deg,var(--gl),var(--go));color:#16110A;font-weight:900;font-size:.95rem;padding:8px 12px;border-radius:12px;box-shadow:0 8px 20px rgba(203,170,106,.45);}
