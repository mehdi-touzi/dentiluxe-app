    #dlp-{{ section.id }} .dlp-wrap{padding-bottom:90px;}
    #dlp-{{ section.id }} .dlp-sticky{display:flex;}
  }
</style>

<script>
  (function(){
    var root=document.getElementById('dlp-{{ section.id }}');
    if(!root)return;
    var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var main=document.getElementById('dlp-main-{{ section.id }}');
    root.querySelectorAll('.dlp-thumb').forEach(function(t){
      t.addEventListener('click',function(){
        if(main)main.src=t.getAttribute('data-full');
        root.querySelectorAll('.dlp-thumb').forEach(function(x){x.classList.remove('is-active');});
        t.classList.add('is-active');
      });
    });
    var items=root.querySelectorAll('.dlp-rv');
    if('IntersectionObserver' in window && !reduce){
      var io=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting){x.target.classList.add('dl-in');io.unobserve(x.target);}});},{threshold:.12});
      items.forEach(function(el){io.observe(el);});
    }else{items.forEach(function(el){el.classList.add('dl-in');});}

    // Pack selector → updates every buy form + price displays
    var packs=root.querySelectorAll('.dlp-pack');
    function selectPack(pack){
      packs.forEach(function(x){x.classList.remove('is-sel');var r=x.querySelector('input');if(r)r.checked=false;});
      pack.classList.add('is-sel');
      var r=pack.querySelector('input');if(r)r.checked=true;
      var vid=pack.getAttribute('data-vid');
      var now=pack.getAttribute('data-now');
      var old=pack.getAttribute('data-old');
      var save=pack.getAttribute('data-save');
      var label=pack.getAttribute('data-label');
      root.querySelectorAll('.dlp-vid').forEach(function(i){i.value=vid;i.dispatchEvent(new Event('input',{bubbles:true}));i.dispatchEvent(new Event('change',{bubbles:true}));});
      try{ history.replaceState({}, '', window.location.pathname + '?variant=' + vid); }catch(e){}
      document.dispatchEvent(new CustomEvent('variant:change',{bubbles:true,detail:{variant:{id:parseInt(vid,10)}}}));
      root.querySelectorAll('.dlp-jnow').forEach(function(e){e.textContent=now;});
      root.querySelectorAll('.dlp-jold').forEach(function(e){e.textContent=old||'';e.style.display=old?'':'none';});
      var sv=root.querySelector('.dlp-jsave');if(sv){sv.textContent=save||'';}
      var btn=root.querySelector('.dlp-jbtn');if(btn){btn.textContent=label;}
    }
    packs.forEach(function(pack){
      pack.addEventListener('click',function(){selectPack(pack);});
    });

    // Review photo lightbox
    var lb=document.getElementById('dlp-lb-{{ section.id }}');
    if(lb){
      var lbImg=lb.querySelector('.dlp-lb__img');
      var photos=Array.prototype.slice.call(root.querySelectorAll('.dlp-rvphoto'));
      var cur=0;
      function show(i){cur=(i+photos.length)%photos.length;lbImg.src=photos[cur].getAttribute('data-full');}
      function open(i){show(i);lb.classList.add('is-open');lb.setAttribute('aria-hidden','false');document.body.style.overflow='hidden';}
      function close(){lb.classList.remove('is-open');lb.setAttribute('aria-hidden','true');document.body.style.overflow='';}
      photos.forEach(function(p,i){p.addEventListener('click',function(){open(i);});});
      lb.querySelector('.dlp-lb__x').addEventListener('click',close);
      lb.querySelector('.dlp-lb__prev').addEventListener('click',function(){show(cur-1);});
      lb.querySelector('.dlp-lb__next').addEventListener('click',function(){show(cur+1);});
      lb.addEventListener('click',function(e){if(e.target===lb)close();});
      document.addEventListener('keydown',function(e){if(!lb.classList.contains('is-open'))return;if(e.key==='Escape')close();else if(e.key==='ArrowLeft')show(cur-1);else if(e.key==='ArrowRight')show(cur+1);});
    }
  })();
</script>

