  #dlp-{{ section.id }} .dlp-faq summary{list-style:none;cursor:pointer;padding:16px 18px;font-weight:700;font-size:.95rem;display:flex;align-items:center;justify-content:space-between;gap:10px;}
  #dlp-{{ section.id }} .dlp-faq summary::-webkit-details-marker{display:none;}
  #dlp-{{ section.id }} .dlp-chev{color:var(--go);transition:transform .2s;font-size:1.2rem;}
  #dlp-{{ section.id }} .dlp-faq details[open] .dlp-chev{transform:rotate(180deg);}
  #dlp-{{ section.id }} .dlp-faq p{padding:0 18px 16px;margin:0;color:var(--dm);font-size:.9rem;line-height:1.65;}

  #dlp-{{ section.id }} .dlp-final{text-align:center;margin:60px 0 0;background:radial-gradient(circle at 50% 0%,#16203A,#0B1320);border:1px solid var(--nb);border-radius:24px;padding:44px 24px;}
  #dlp-{{ section.id }} .dlp-final__h{font-family:'Playfair Display',serif;font-size:1.9rem;font-weight:700;margin:0 0 8px;}
  #dlp-{{ section.id }} .dlp-final__p{color:var(--dm);margin:0 0 16px;font-size:.95rem;}
  #dlp-{{ section.id }} .dlp-final__price{display:flex;justify-content:center;align-items:baseline;gap:12px;margin-bottom:18px;}
  #dlp-{{ section.id }} .dlp-final .dlp-btn{max-width:420px;margin:0 auto;}

  #dlp-{{ section.id }} .dlp-rv{opacity:0;transform:translateY(26px);transition:opacity .7s ease,transform .7s cubic-bezier(.2,.7,.2,1);}
  #dlp-{{ section.id }} .dlp-rv.dl-in{opacity:1;transform:none;}

  #dlp-{{ section.id }} .dlp-sticky{position:fixed;left:0;right:0;bottom:0;z-index:40;display:none;align-items:center;gap:12px;background:rgba(11,19,32,.96);backdrop-filter:blur(10px);border-top:1px solid var(--nb);padding:10px 14px;}
  #dlp-{{ section.id }} .dlp-sticky__p{display:flex;align-items:baseline;gap:8px;}#dlp-{{ section.id }} .dlp-sticky__p .dlp-now{font-size:1.3rem;}
  #dlp-{{ section.id }} .dlp-sticky__f{flex:1;margin:0;}#dlp-{{ section.id }} .dlp-sticky .dlp-btn{padding:14px;border-radius:12px;}

  @media (prefers-reduced-motion: reduce){#dlp-{{ section.id }} .dlp-rv{opacity:1;transform:none;transition:none;}#dlp-{{ section.id }} .dlp-main{transition:none;}}
  @media (max-width:860px){
    #dlp-{{ section.id }} .dlp-top{grid-template-columns:1fr;gap:24px;}
