  #dlp-{{ section.id }} .dlp-rvphoto__badge{position:absolute;left:8px;bottom:8px;background:rgba(11,19,32,.82);color:var(--gn);font-size:.68rem;font-weight:700;padding:4px 8px;border-radius:999px;backdrop-filter:blur(4px);line-height:1;}
  #dlp-{{ section.id }} .dlp-rvcap{padding:11px 4px 0;}
