  #dlp-{{ section.id }} .dlp-lb{position:fixed;inset:0;z-index:9999;background:rgba(4,8,16,.93);display:none;align-items:center;justify-content:center;padding:24px;backdrop-filter:blur(6px);}
  #dlp-{{ section.id }} .dlp-lb.is-open{display:flex;}
  #dlp-{{ section.id }} .dlp-lb__img{max-width:min(92vw,460px);max-height:88vh;border-radius:14px;box-shadow:0 30px 80px rgba(0,0,0,.6);}
  #dlp-{{ section.id }} .dlp-lb__x{position:absolute;top:16px;right:20px;width:46px;height:46px;border-radius:50%;border:none;background:rgba(255,255,255,.14);color:#fff;font-size:1.7rem;line-height:1;cursor:pointer;}
  #dlp-{{ section.id }} .dlp-lb__nav{position:absolute;top:50%;transform:translateY(-50%);width:50px;height:50px;border-radius:50%;border:none;background:rgba(255,255,255,.14);color:#fff;font-size:2rem;line-height:1;cursor:pointer;}
  #dlp-{{ section.id }} .dlp-lb__prev{left:16px;}#dlp-{{ section.id }} .dlp-lb__next{right:16px;}
  #dlp-{{ section.id }} .dlp-lb__x:hover,#dlp-{{ section.id }} .dlp-lb__nav:hover{background:rgba(255,255,255,.26);}

  #dlp-{{ section.id }} .dlp-faq{max-width:760px;margin:0 auto;}
