    #dlp-{{ section.id }} .dlp-title{font-size:1.7rem;}
    #dlp-{{ section.id }} .dlp-grid{grid-template-columns:1fr 1fr;}
    #dlp-{{ section.id }} .dlp-split{grid-template-columns:1fr;}
    #dlp-{{ section.id }} .dlp-reviews{grid-template-columns:repeat(2,1fr);gap:12px;}
    #dlp-{{ section.id }} .dlp-showrow{grid-template-columns:1fr;gap:14px;}
