{%- assign p = all_products['hydropulseur-denti-luxe-jet-dentaire-sans-fil'] -%}
{%- assign v = p.selected_or_first_available_variant -%}
{%- assign disc = 0 -%}
{%- if p.compare_at_price > p.price -%}
  {%- assign disc = p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price -%}
{%- endif -%}

<section class="dl" id="dl-{{ section.id }}">
  {%- comment -%} SEO — Données structurées Organisation + Site {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Denti Luxe",
    "url": "{{ shop.url }}{{ routes.root_url }}",
    {% if settings.logo %}"logo": "{{ settings.logo | image_url: width: 400 | prepend: 'https:' }}",{% endif %}
    "description": "Denti Luxe — Hydropulseur et soins bucco-dentaires premium au Maroc. Paiement à la livraison, livraison 24–72h.",
    "areaServed": "MA"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Denti Luxe",
    "url": "{{ shop.url }}{{ routes.root_url }}",
    "inLanguage": "fr-MA",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ shop.url }}/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <!-- CINEMATIC INTRO -->
  <div class="dl-intro" aria-hidden="true">
    <div class="dl-intro__inner">
      {% if settings.logo %}<img class="dl-intro__logo" src="{{ settings.logo | image_url: width: 200 }}" alt="" width="92" height="92">{% endif %}
      <div class="dl-intro__word">Denti&nbsp;Luxe</div>
      <span class="dl-intro__line"></span>
      <div class="dl-intro__tag">L’art du sourire</div>
    </div>
  </div>

  <div class="dl-announce">
    <span class="dl-dot"></span> Offre de lancement{% if disc > 0 %} · −{{ disc }}%{% endif %} · Paiement à la livraison partout au Maroc
  </div>

  <!-- HERO -->
  <div class="dl-hero">
    <div class="dl-hero__stage dl-cinstage">
      <div class="dl-hero__media" data-dl-tilt>
        {%- if p.featured_image -%}
          <img src="{{ p.featured_image | image_url: width: 1200 }}" alt="{{ p.title | escape }}" width="600" height="450" loading="eager" class="dl-hero__img">
        {%- endif -%}
        {% if disc > 0 %}
          <div class="dl-coin" aria-hidden="true">
            <div class="dl-coin__inner"><span>−{{ disc }}%</span></div>
          </div>
        {% endif %}
      </div>
    </div>
    <div class="dl-hero__body">
      {% if settings.logo %}<img class="dl-logo dl-cin dl-d1" src="{{ settings.logo | image_url: width: 240 }}" alt="{{ shop.name | escape }}" width="120" height="120">{% endif %}
      <div class="dl-eyebrow dl-cin dl-d2">Hydropulseur sans fil · Denti Luxe</div>
      <h1 class="dl-h1 dl-cin dl-d3">Un sourire propre et sain,<br><span class="dl-gold">comme chez le dentiste</span></h1>
      <div class="dl-stars-row dl-cin dl-d4">
        <span class="dl-stars">★★★★★</span>
        <span class="dl-muted">noté 4.9/5 par +1 200 clients</span>
      </div>
      <p class="dl-lead dl-cin dl-d5">Le jet d’eau pulsé qui nettoie en profondeur là où la brosse et le fil n’atteignent pas. Idéal pour <b>facettes, bridges &amp; gencives sensibles</b>.</p>
      <div class="dl-price dl-cin dl-d6">
        <span class="dl-price__now">{{ p.price | money }}</span>
        {% if p.compare_at_price > p.price %}<span class="dl-price__old">{{ p.compare_at_price | money }}</span>{% endif %}
      </div>
      <div class="dl-trust dl-cin dl-d6b"><span class="dl-check">✓</span> En stock · Livraison 24–72h · Vous payez à la réception</div>
      <a href="{{ p.url }}" class="dl-cta dl-cin dl-d7">Commander maintenant — {{ p.price | money }}</a>
      <a href="{{ p.url }}" class="dl-link dl-cin dl-d8">Voir tous les détails du produit →</a>
    </div>
  </div>

  <div class="dl-wrap">
    <!-- STATS -->
    <div class="dl-stats dl-reveal">
      <div class="dl-stat"><div class="dl-stat__v">3 370+</div><div class="dl-stat__l">abonnés</div></div>
      <div class="dl-stat"><div class="dl-stat__v">4.9/5</div><div class="dl-stat__l">satisfaction</div></div>
      <div class="dl-stat"><div class="dl-stat__v">+1 200</div><div class="dl-stat__l">sourires</div></div>
    </div>

    <!-- GALLERY -->
    <h2 class="dl-h2 dl-reveal">Découvrez-le sous tous les angles</h2>
    <div class="dl-gal">
      {%- for media in p.media limit: 6 -%}
        <figure class="dl-gal__i dl-reveal">
          <img src="{{ media | image_url: width: 900 }}" alt="{{ p.title | escape }} — visuel {{ forloop.index }}" loading="lazy">
          <span class="dl-gal__sh"></span>
        </figure>
      {%- endfor -%}
    </div>

    <!-- BENEFITS -->
    <h2 class="dl-h2 dl-reveal">Pourquoi vous allez l’adopter</h2>
    <div class="dl-grid">
      <div class="dl-card dl-reveal">
        <svg class="dl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l1.6 6.4L20 10l-6.4 1.6L12 18l-1.6-6.4L4 10l6.4-1.6z"/></svg>
        <h3>Nettoyage en profondeur</h3><p>Atteint les zones inaccessibles à la brosse.</p>
      </div>
      <div class="dl-card dl-reveal">
        <svg class="dl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <h3>Protège vos facettes</h3><p>Nettoie en douceur facettes, bridges &amp; implants.</p>
      </div>
      <div class="dl-card dl-reveal">
        <svg class="dl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20M8 14s1.5 2 4 2 4-2 4-2M9 9v.01M15 9v.01"/></svg>
        <h3>Gencives plus saines</h3><p>Réduit la plaque et la mauvaise haleine.</p>
      </div>
      <div class="dl-card dl-reveal">
        <svg class="dl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9z"/></svg>
        <h3>Sans fil &amp; étanche</h3><p>3 modes de jet · rechargeable USB · IPX7.</p>
      </div>
    </div>

    <!-- HOW IT WORKS -->
    <h2 class="dl-h2 dl-reveal">Comment ça marche</h2>
    <div class="dl-steps">
      <div class="dl-step dl-reveal"><span class="dl-step__n">1</span><span>Remplissez le réservoir d’eau</span></div>
      <div class="dl-step dl-reveal"><span class="dl-step__n">2</span><span>Choisissez votre mode de jet</span></div>
      <div class="dl-step dl-reveal"><span class="dl-step__n">3</span><span>Passez entre les dents — propre en 1 minute&nbsp;!</span></div>
    </div>

    <!-- REVIEWS -->
    <div class="dl-rev-head dl-reveal">
      <h2 class="dl-h2 dl-h2--flush">Avis clients</h2>
      <span class="dl-stars">★★★★★ <span class="dl-muted">4.9/5</span></span>
    </div>
    <div class="dl-reviews">
      <figure class="dl-review dl-reveal">
        <div class="dl-review__top"><span class="dl-av">S</span><div><b>Salma</b> · Rabat<br><span class="dl-verif">✓ Achat vérifié</span></div></div>
        <blockquote>« Depuis que j’ai mes facettes, l’hydropulseur est devenu indispensable. Mes gencives sont nickel ! »</blockquote>
      </figure>
      <figure class="dl-review dl-reveal">
        <div class="dl-review__top"><span class="dl-av">Y</span><div><b>Yassine</b> · Témara<br><span class="dl-verif">✓ Achat vérifié</span></div></div>
        <blockquote>« Sans fil, batterie qui tient, super pratique. Livraison rapide et payé à la réception. Top. »</blockquote>
      </figure>
      <figure class="dl-review dl-reveal">
        <div class="dl-review__top"><span class="dl-av">I</span><div><b>Imane</b> · Casablanca<br><span class="dl-verif">✓ Achat vérifié</span></div></div>
        <blockquote>« Sensation de propreté incroyable, comme après un détartrage. J’adore ✨ »</blockquote>
      </figure>
    </div>

    <!-- GUARANTEES -->
    <div class="dl-guars">
      <div class="dl-guar dl-reveal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h20v12H2zM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6"/></svg><span>Paiement à la livraison</span></div>
      <div class="dl-guar dl-reveal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h11v9H3zM14 9h4l3 3v3h-7zM7 18a2 2 0 1 0 .01 0M17 18a2 2 0 1 0 .01 0"/></svg><span>Livraison partout au Maroc</span></div>
      <div class="dl-guar dl-reveal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg><span>Satisfait ou remboursé</span></div>
    </div>

    <!-- FAQ -->
    <h2 class="dl-h2 dl-reveal">Questions fréquentes</h2>
    <div class="dl-faq dl-reveal">
      <details><summary>C’est compatible avec mes facettes / bridges ?<span class="dl-chev">⌄</span></summary><p>Oui, c’est même recommandé : le jet d’eau nettoie en douceur autour des facettes, bridges et implants sans les abîmer.</p></details>
      <details><summary>Ça remplace le fil dentaire ?<span class="dl-chev">⌄</span></summary><p>Oui, et c’est plus efficace et plus doux pour les gencives. Le jet déloge les résidus là où la brosse n’atteint pas.</p></details>
      <details><summary>La batterie tient combien de temps ?<span class="dl-chev">⌄</span></summary><p>Plusieurs jours d’utilisation par charge. Il est sans fil, étanche (IPX7) et se recharge en USB.</p></details>
      <details><summary>Comment je paie ?<span class="dl-chev">⌄</span></summary><p>Vous payez à la livraison (cash), une fois le colis reçu chez vous. Aucune avance.</p></details>
      <details><summary>Vous livrez où ?<span class="dl-chev">⌄</span></summary><p>Partout au Maroc, en 24 à 72h selon votre ville.</p></details>
    </div>

    <!-- FINAL CTA -->
    <div class="dl-final dl-reveal">
      <h2 class="dl-final__h">Prêt à retrouver un sourire éclatant ?</h2>
      <p class="dl-final__p">Commandez en 30 secondes · Paiement à la livraison · Satisfait ou remboursé.</p>
      <div class="dl-final__price">
        <span class="dl-price__now">{{ p.price | money }}</span>
        {% if p.compare_at_price > p.price %}<span class="dl-price__old">{{ p.compare_at_price | money }}</span>{% endif %}
      </div>
      <a href="{{ p.url }}" class="dl-cta">Je commande maintenant</a>
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800;900&family=Playfair+Display:wght@600;700;800&display=swap');
  #dl-{{ section.id }}{
    --nv:#0B1320;--nv2:#10182A;--nv3:#16203A;--nb:#26314B;--go:#CBAA6A;--gl:#E6D09A;
    --tx:#EEF1F6;--dm:#A7AFBF;--mt:#717B90;--gn:#33BA86;--rd:#E45A6E;
    font-family:'DM Sans',system-ui,sans-serif;color:var(--tx);background:var(--nv);
    display:block;overflow:hidden;position:relative;
  }
  #dl-{{ section.id }} *{box-sizing:border-box;}
  #dl-{{ section.id }} .dl-wrap{max-width:1080px;margin:0 auto;padding:0 20px;}
  #dl-{{ section.id }} .dl-gold{color:var(--go);}
  #dl-{{ section.id }} .dl-muted{color:var(--dm);font-size:.82rem;font-weight:500;}
  #dl-{{ section.id }} .dl-stars{color:var(--go);letter-spacing:2px;}

  /* ===== CINEMATIC INTRO ===== */
  #dl-{{ section.id }} .dl-intro{position:fixed;inset:0;z-index:9999;background:radial-gradient(circle at 50% 38%,#16203A 0%,#0A0F1A 55%,#05080F 100%);display:flex;align-items:center;justify-content:center;animation:dl-introhide 2.9s cubic-bezier(.76,0,.24,1) forwards;}
  #dl-{{ section.id }} .dl-intro__inner{display:flex;flex-direction:column;align-items:center;gap:16px;text-align:center;}
  #dl-{{ section.id }} .dl-intro__logo{width:92px;height:92px;object-fit:contain;opacity:0;filter:drop-shadow(0 10px 30px rgba(0,0,0,.6));animation:dl-iup .9s .1s cubic-bezier(.2,.7,.2,1) both;}
  #dl-{{ section.id }} .dl-intro__word{font-family:'Playfair Display',serif;font-weight:800;font-size:2.4rem;opacity:0;animation:dl-iword 1.1s .45s cubic-bezier(.2,.7,.2,1) both;background:linear-gradient(95deg,var(--go),#F4E6C0,var(--go));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
  #dl-{{ section.id }} .dl-intro__line{display:block;width:0;height:1px;background:linear-gradient(90deg,transparent,var(--go),transparent);animation:dl-iline .9s .85s cubic-bezier(.2,.7,.2,1) both;}
  #dl-{{ section.id }} .dl-intro__tag{font-size:.74rem;letter-spacing:.42em;text-transform:uppercase;color:var(--dm);opacity:0;animation:dl-iup .9s 1.05s ease both;}
  @keyframes dl-introhide{0%,66%{opacity:1;transform:translateY(0)}100%{opacity:0;transform:translateY(-40px);visibility:hidden;pointer-events:none}}
  @keyframes dl-iup{0%{opacity:0;transform:translateY(16px) scale(.94)}100%{opacity:1;transform:none}}
  @keyframes dl-iword{0%{opacity:0;letter-spacing:.5em;transform:translateY(10px)}100%{opacity:1;letter-spacing:.04em;transform:none}}
  @keyframes dl-iline{0%{width:0;opacity:0}100%{width:170px;opacity:1}}

  /* ===== HERO CINEMATIC REVEAL ===== */
  #dl-{{ section.id }} .dl-cin{opacity:0;animation:dl-cin .9s cubic-bezier(.2,.7,.2,1) both;}
  #dl-{{ section.id }} .dl-d1{animation-delay:1.95s}
  #dl-{{ section.id }} .dl-d2{animation-delay:2.05s}
  #dl-{{ section.id }} .dl-d3{animation-delay:2.18s}
  #dl-{{ section.id }} .dl-d4{animation-delay:2.32s}
  #dl-{{ section.id }} .dl-d5{animation-delay:2.44s}
  #dl-{{ section.id }} .dl-d6{animation-delay:2.56s}
  #dl-{{ section.id }} .dl-d6b{animation-delay:2.66s}
  #dl-{{ section.id }} .dl-d7{animation-delay:2.78s}
  #dl-{{ section.id }} .dl-d8{animation-delay:2.9s}
  @keyframes dl-cin{0%{opacity:0;transform:translateY(24px)}100%{opacity:1;transform:none}}
  #dl-{{ section.id }} .dl-cinstage{animation:dl-cinstage 1.3s 1.75s cubic-bezier(.2,.7,.2,1) both;}
  @keyframes dl-cinstage{0%{opacity:0;transform:translateY(34px) scale(.95);filter:blur(12px)}100%{opacity:1;transform:none;filter:none}}

  #dl-{{ section.id }} .dl-announce{background:linear-gradient(90deg,rgba(203,170,106,.18),rgba(203,170,106,.05));border-bottom:1px solid var(--nb);text-align:center;padding:10px 16px;font-size:.78rem;font-weight:600;color:var(--gl);letter-spacing:.2px;display:flex;gap:8px;align-items:center;justify-content:center;}
  #dl-{{ section.id }} .dl-dot{width:7px;height:7px;border-radius:50%;background:var(--gn);box-shadow:0 0 0 4px rgba(51,186,134,.18);}

  #dl-{{ section.id }} .dl-hero{max-width:1080px;margin:0 auto;padding:40px 20px 8px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;}
  #dl-{{ section.id }} .dl-hero__stage{perspective:1100px;}
  #dl-{{ section.id }} .dl-hero__media{position:relative;border-radius:24px;overflow:hidden;border:1px solid var(--nb);background:radial-gradient(circle at 50% 30%,#1B263F,#0A1120);aspect-ratio:4/3;box-shadow:0 30px 70px rgba(0,0,0,.5);transform-style:preserve-3d;transition:transform .25s ease-out;will-change:transform;}
  #dl-{{ section.id }} .dl-hero__img{width:100%;height:100%;object-fit:cover;display:block;transform:translateZ(40px) scale(1.04);}
  #dl-{{ section.id }} .dl-coin{position:absolute;bottom:16px;right:16px;width:84px;height:84px;perspective:600px;transform:translateZ(70px);}
  #dl-{{ section.id }} .dl-coin__inner{width:100%;height:100%;border-radius:50%;background:linear-gradient(135deg,var(--gl),var(--go));color:#16110A;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:1.1rem;box-shadow:0 10px 26px rgba(203,170,106,.5),inset 0 0 0 3px rgba(255,255,255,.35);transform-style:preserve-3d;animation:dl-spin 5s linear infinite;}

  #dl-{{ section.id }} .dl-logo{width:84px;height:84px;object-fit:contain;margin-bottom:14px;filter:drop-shadow(0 8px 20px rgba(0,0,0,.5));}
  #dl-{{ section.id }} .dl-eyebrow{font-size:.78rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--go);margin-bottom:12px;}
  #dl-{{ section.id }} .dl-h1{font-family:'Playfair Display',serif;font-weight:800;font-size:2.6rem;line-height:1.1;margin:0 0 14px;letter-spacing:-.5px;}
  #dl-{{ section.id }} .dl-stars-row{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
  #dl-{{ section.id }} .dl-lead{color:var(--dm);font-size:1.02rem;line-height:1.65;margin:0 0 18px;max-width:520px;}
  #dl-{{ section.id }} .dl-price{display:flex;align-items:baseline;gap:12px;margin-bottom:10px;}
  #dl-{{ section.id }} .dl-price__now{font-family:'Playfair Display',serif;font-size:2.3rem;font-weight:800;background:linear-gradient(95deg,var(--go),var(--gl));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
  #dl-{{ section.id }} .dl-price__old{font-size:1.1rem;color:var(--mt);text-decoration:line-through;}
  #dl-{{ section.id }} .dl-trust{display:flex;align-items:center;gap:8px;font-size:.86rem;color:var(--gn);font-weight:600;margin-bottom:20px;}
  #dl-{{ section.id }} .dl-check{display:inline-flex;width:18px;height:18px;align-items:center;justify-content:center;border-radius:50%;background:rgba(51,186,134,.16);font-size:.7rem;}
  #dl-{{ section.id }} .dl-form{margin:0 0 12px;}
  #dl-{{ section.id }} .dl-btn{display:flex;width:100%;max-width:420px;align-items:center;justify-content:center;gap:9px;background:linear-gradient(180deg,var(--gl),var(--go));color:#16110A;border:none;border-radius:16px;padding:18px 22px;font-weight:800;font-size:1.05rem;letter-spacing:.2px;cursor:pointer;box-shadow:0 12px 30px rgba(203,170,106,.32);transition:transform .12s,box-shadow .2s;font-family:inherit;}
  #dl-{{ section.id }} .dl-btn:hover{transform:translateY(-2px);box-shadow:0 16px 38px rgba(203,170,106,.42);}
  #dl-{{ section.id }} .dl-btn:active{transform:translateY(0);}
  #dl-{{ section.id }} .dl-btn[disabled]{opacity:.5;cursor:not-allowed;box-shadow:none;}
  #dl-{{ section.id }} .dl-cta{display:flex;width:100%;max-width:420px;align-items:center;justify-content:center;text-align:center;gap:9px;margin:0 0 12px;background:linear-gradient(180deg,var(--gl),var(--go));color:#16110A;border-radius:16px;padding:18px 22px;font-weight:800;font-size:1.05rem;letter-spacing:.2px;cursor:pointer;text-decoration:none;box-shadow:0 12px 30px rgba(203,170,106,.32);transition:transform .12s,box-shadow .2s;}
  #dl-{{ section.id }} .dl-cta:hover{transform:translateY(-2px);box-shadow:0 16px 38px rgba(203,170,106,.42);color:#16110A;}
  #dl-{{ section.id }} .dl-final .dl-cta{margin:6px auto 0;}
  #dl-{{ section.id }} .dl-link{display:inline-block;color:var(--dm);font-size:.85rem;text-decoration:none;border-bottom:1px solid var(--nb);padding-bottom:2px;}
  #dl-{{ section.id }} .dl-link:hover{color:var(--gl);}

  #dl-{{ section.id }} .dl-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:44px 0 8px;}
  #dl-{{ section.id }} .dl-stat{background:var(--nv2);border:1px solid var(--nb);border-radius:16px;text-align:center;padding:18px 8px;}
  #dl-{{ section.id }} .dl-stat__v{font-family:'Playfair Display',serif;font-size:1.7rem;font-weight:800;background:linear-gradient(95deg,var(--go),var(--gl));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
  #dl-{{ section.id }} .dl-stat__l{font-size:.72rem;color:var(--mt);text-transform:uppercase;letter-spacing:1px;margin-top:4px;}

  #dl-{{ section.id }} .dl-h2{font-family:'Playfair Display',serif;font-size:1.85rem;font-weight:700;text-align:center;margin:54px 0 24px;}
  #dl-{{ section.id }} .dl-h2--flush{margin:0;text-align:left;}

  /* GALLERY (bento) */
  #dl-{{ section.id }} .dl-gal{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:170px;gap:14px;}
  #dl-{{ section.id }} .dl-gal__i{position:relative;margin:0;border-radius:18px;overflow:hidden;border:1px solid var(--nb);background:#0A1120;}
  #dl-{{ section.id }} .dl-gal__i img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s cubic-bezier(.2,.7,.2,1);}
  #dl-{{ section.id }} .dl-gal__i:hover img{transform:scale(1.08);}
  #dl-{{ section.id }} .dl-gal__sh{position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(7,12,22,.55));pointer-events:none;}
  #dl-{{ section.id }} .dl-gal__i:nth-child(1){grid-column:span 2;grid-row:span 2;}
  #dl-{{ section.id }} .dl-gal__i:nth-child(4){grid-column:span 2;}

  #dl-{{ section.id }} .dl-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;perspective:1000px;}
  #dl-{{ section.id }} .dl-card{background:var(--nv2);border:1px solid var(--nb);border-radius:18px;padding:22px;transition:transform .25s,border-color .25s,box-shadow .25s;transform-style:preserve-3d;}
  #dl-{{ section.id }} .dl-card:hover{transform:translateY(-6px) rotateX(6deg) rotateY(-4deg);border-color:rgba(203,170,106,.55);box-shadow:0 22px 44px rgba(0,0,0,.45);}
  #dl-{{ section.id }} .dl-ico{width:30px;height:30px;color:var(--go);margin-bottom:12px;}
  #dl-{{ section.id }} .dl-card h3{font-size:1rem;font-weight:700;margin:0 0 6px;}
  #dl-{{ section.id }} .dl-card p{font-size:.85rem;color:var(--dm);line-height:1.55;margin:0;}

  #dl-{{ section.id }} .dl-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  #dl-{{ section.id }} .dl-step{display:flex;align-items:center;gap:14px;background:var(--nv2);border:1px solid var(--nb);border-radius:16px;padding:18px;font-size:.95rem;}
  #dl-{{ section.id }} .dl-step__n{flex-shrink:0;width:38px;height:38px;border-radius:12px;background:rgba(203,170,106,.14);color:var(--go);display:flex;align-items:center;justify-content:center;font-weight:800;font-family:'Playfair Display',serif;font-size:1.1rem;}

  #dl-{{ section.id }} .dl-rev-head{display:flex;align-items:center;justify-content:space-between;margin:54px 0 22px;}
  #dl-{{ section.id }} .dl-reviews{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  #dl-{{ section.id }} .dl-review{background:var(--nv2);border:1px solid var(--nb);border-radius:18px;padding:20px;margin:0;}
  #dl-{{ section.id }} .dl-review__top{display:flex;align-items:center;gap:12px;margin-bottom:12px;font-size:.85rem;}
  #dl-{{ section.id }} .dl-av{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--go),var(--gl));color:#16110A;display:flex;align-items:center;justify-content:center;font-weight:800;}
  #dl-{{ section.id }} .dl-verif{color:var(--gn);font-size:.74rem;font-weight:600;}
  #dl-{{ section.id }} .dl-review blockquote{margin:0;font-size:.92rem;color:var(--dm);line-height:1.65;font-style:italic;}

  #dl-{{ section.id }} .dl-guars{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:30px 0 0;}
  #dl-{{ section.id }} .dl-guar{display:flex;flex-direction:column;align-items:center;gap:10px;text-align:center;background:var(--nv2);border:1px solid var(--nb);border-radius:16px;padding:22px 14px;font-size:.85rem;color:var(--dm);font-weight:600;}
  #dl-{{ section.id }} .dl-guar svg{width:28px;height:28px;color:var(--go);}

  #dl-{{ section.id }} .dl-faq{max-width:760px;margin:0 auto;}
  #dl-{{ section.id }} .dl-faq details{background:var(--nv2);border:1px solid var(--nb);border-radius:14px;margin-bottom:10px;overflow:hidden;}
  #dl-{{ section.id }} .dl-faq summary{list-style:none;cursor:pointer;padding:16px 18px;font-weight:700;font-size:.95rem;display:flex;align-items:center;justify-content:space-between;gap:10px;}
  #dl-{{ section.id }} .dl-faq summary::-webkit-details-marker{display:none;}
  #dl-{{ section.id }} .dl-chev{color:var(--go);transition:transform .2s;font-size:1.2rem;}
  #dl-{{ section.id }} .dl-faq details[open] .dl-chev{transform:rotate(180deg);}
  #dl-{{ section.id }} .dl-faq p{padding:0 18px 16px;margin:0;color:var(--dm);font-size:.9rem;line-height:1.65;}

  #dl-{{ section.id }} .dl-final{text-align:center;margin:60px 0 70px;background:radial-gradient(circle at 50% 0%,#16203A,#0B1320);border:1px solid var(--nb);border-radius:24px;padding:44px 24px;}
  #dl-{{ section.id }} .dl-final__h{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;margin:0 0 8px;}
  #dl-{{ section.id }} .dl-final__p{color:var(--dm);margin:0 0 16px;font-size:.95rem;}
  #dl-{{ section.id }} .dl-final__price{display:flex;justify-content:center;align-items:baseline;gap:12px;margin-bottom:18px;}
  #dl-{{ section.id }} .dl-final .dl-btn{margin:0 auto;}

  @keyframes dl-spin{0%{transform:rotateY(0deg);}100%{transform:rotateY(360deg);}}
  #dl-{{ section.id }} .dl-reveal{opacity:0;transform:translateY(28px) rotateX(8deg);transition:opacity .7s ease,transform .7s cubic-bezier(.2,.7,.2,1);transform-origin:center top;}
  #dl-{{ section.id }} .dl-reveal.dl-in{opacity:1;transform:none;}

  @media (prefers-reduced-motion: reduce){
    #dl-{{ section.id }} .dl-intro{display:none;}
    #dl-{{ section.id }} .dl-cin,#dl-{{ section.id }} .dl-cinstage{animation:none;opacity:1;transform:none;filter:none;}
    #dl-{{ section.id }} .dl-coin__inner{animation:none;}
    #dl-{{ section.id }} .dl-reveal{opacity:1;transform:none;transition:none;}
    #dl-{{ section.id }} .dl-hero__media{transition:none;}
  }

  @media (max-width:820px){
    #dl-{{ section.id }} .dl-intro__word{font-size:1.9rem;}
    #dl-{{ section.id }} .dl-hero{grid-template-columns:1fr;gap:24px;padding-top:28px;}
    #dl-{{ section.id }} .dl-h1{font-size:2.05rem;}
    #dl-{{ section.id }} .dl-gal{grid-auto-rows:130px;}
    #dl-{{ section.id }} .dl-grid{grid-template-columns:1fr 1fr;}
    #dl-{{ section.id }} .dl-steps,#dl-{{ section.id }} .dl-reviews,#dl-{{ section.id }} .dl-guars{grid-template-columns:1fr;}
    #dl-{{ section.id }} .dl-btn{max-width:none;}
    #dl-{{ section.id }} .dl-logo{width:64px;height:64px;}
  }
</style>

<script>
  (function(){
    var root = document.getElementById('dl-{{ section.id }}');
    if(!root) return;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Remove intro overlay once its animation ends (cleanup)
    var intro = root.querySelector('.dl-intro');
    if(intro){
      if(reduce){ if(intro.parentNode){ intro.parentNode.removeChild(intro); } }
      else {
        intro.addEventListener('animationend', function(e){ if(e.target===intro){ intro.style.display='none'; } });
        setTimeout(function(){ if(intro){ intro.style.display='none'; } }, 3400);
      }
    }

    // Scroll reveal
    var items = root.querySelectorAll('.dl-reveal');
    if('IntersectionObserver' in window && !reduce){
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('dl-in'); io.unobserve(e.target); } });
      }, {threshold:.15});
      items.forEach(function(el){ io.observe(el); });
    } else {
      items.forEach(function(el){ el.classList.add('dl-in'); });
    }

    // 3D tilt on hero media
    if(!reduce){
      var tilt = root.querySelector('[data-dl-tilt]');
      if(tilt){
        var stage = tilt.parentElement;
        stage.addEventListener('mousemove', function(ev){
          var r = tilt.getBoundingClientRect();
          var px = (ev.clientX - r.left) / r.width - .5;
          var py = (ev.clientY - r.top) / r.height - .5;
          tilt.style.transform = 'rotateY(' + (px*14).toFixed(2) + 'deg) rotateX(' + (-py*14).toFixed(2) + 'deg)';
        });
        stage.addEventListener('mouseleave', function(){ tilt.style.transform = 'rotateY(0deg) rotateX(0deg)'; });
      }
    }
  })();
</script>

