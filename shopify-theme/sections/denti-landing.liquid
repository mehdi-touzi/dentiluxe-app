{%- assign p = all_products['hydropulseur-denti-luxe-jet-dentaire-sans-fil'] -%}
{%- assign v = p.selected_or_first_available_variant -%}
{%- assign imgs = p.images -%}
{%- assign img_bg = imgs[4] | default: imgs.last | default: p.featured_image -%}
{%- assign img_life = imgs[3] | default: imgs[1] | default: p.featured_image -%}
{%- assign img_modes = imgs[5] | default: imgs[2] | default: p.featured_image -%}
{%- assign disc = 0 -%}
{%- if p.compare_at_price > p.price -%}
  {%- assign disc = p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price -%}
  {%- assign save = p.compare_at_price | minus: p.price -%}
{%- endif -%}

{{ 'denti-landing.css' | asset_url | stylesheet_tag }}

<div class="dl" id="dl-root">

  <div class="dl-bar"><div class="dl-bar__t">
    {%- for i in (1..2) -%}<span>Paiement à la livraison{% if disc > 0 %} &nbsp;·&nbsp; Offre de lancement −{{ disc }}%{% endif %} &nbsp;·&nbsp; Livraison 24–72h partout au Maroc &nbsp;·&nbsp; Satisfait ou remboursé &nbsp;·&nbsp; Sans fil &amp; étanche IPX7</span>{%- endfor -%}
  </div></div>

  <!-- ===== HERO ===== -->
  <header class="dl-hero">
    {%- if img_bg -%}<div class="dl-hero__bg" id="dl-parallax" style="background-image:url('{{ img_bg | image_url: width: 1900 }}');"></div>{%- endif -%}
    <div class="dl-hero__veil"></div>
    <div class="dl-hero__inner">
      <div class="dl-hero__text">
        {% if settings.logo %}<img class="dl-hero__logo" src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name | escape }}">{% endif %}
        <span class="dl-eyebrow">Hydropulseur sans fil · Denti Luxe</span>
        <h1 class="dl-h1">Un sourire propre et sain,<br><span class="dl-grad">comme chez le dentiste.</span></h1>
        <p class="dl-hero__sub">Le jet d’eau pulsé qui nettoie en profondeur là où la brosse et le fil n’atteignent pas. Conçu pour les <b>facettes, bridges &amp; gencives sensibles</b>.</p>
        <div class="dl-hero__meta"><span class="dl-stars">★★★★★</span><span class="dl-muted">noté 4.9/5 par +1 200 clients</span></div>
        <div class="dl-price">
          <span class="dl-price__now dl-grad">{{ p.price | money }}</span>
          {% if disc > 0 %}<span class="dl-price__old">{{ p.compare_at_price | money }}</span><span class="dl-price__save">−{{ disc }}%</span>{% endif %}
        </div>
        <div class="dl-cta-row">
          {% form 'product', p, class: 'dl-form' %}
            <input type="hidden" name="id" value="{{ v.id }}">
            <input type="hidden" name="return_to" value="/checkout">
            <button type="submit" class="dl-btn" {% unless v.available %}disabled{% endunless %}>{% if v.available %}Commander maintenant{% else %}Rupture de stock{% endif %}</button>
          {% endform %}
          <a href="#decouvrir" class="dl-ghost">Découvrir ▾</a>
        </div>
        <div class="dl-hero__trust">
          <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M2 6h20v12H2z"/><circle cx="12" cy="12" r="3"/></svg> Paiement à la livraison</span>
          <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M3 6h11v9H3zM14 9h4l3 3v3h-7z"/><circle cx="7.5" cy="18" r="1.6"/><circle cx="17.5" cy="18" r="1.6"/></svg> Livraison 24–72h</span>
          <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg> Satisfait ou remboursé</span>
        </div>
      </div>
      <div class="dl-hero__stage">
        <div class="dl-hero__card" data-tilt>
          {% if p.featured_image %}<img src="{{ p.featured_image | image_url: width: 900 }}" alt="{{ p.title | escape }}">{% endif %}
          {% if disc > 0 %}<div class="dl-coin">−{{ disc }}%</div>{% endif %}
        </div>
      </div>
    </div>
    <div class="dl-scroll"><span>Scroll</span><i></i></div>
  </header>

  <!-- ===== STATS ===== -->
  <section id="decouvrir"><div class="dl-wrap">
    <div class="dl-stats dl-rv">
      <div class="dl-stat"><div class="dl-stat__v dl-grad" data-count="3370" data-suffix="+">0</div><div class="dl-stat__l">abonnés</div></div>
      <div class="dl-stat"><div class="dl-stat__v dl-grad">4.9/5</div><div class="dl-stat__l">satisfaction</div></div>
