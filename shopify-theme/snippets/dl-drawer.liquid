{%- comment -%} Denti Luxe — enrichit le menu mobile (drawer) : logo, liens travaillés, CTA COD {%- endcomment -%}
{%- assign dl_p = all_products['hydropulseur-denti-luxe-jet-dentaire-sans-fil'] -%}

<template id="dl-drawer-x">
  <div class="dl-mh">
    {% if settings.logo %}<img class="dl-mh__logo" src="{{ settings.logo | image_url: width: 220 }}" alt="{{ shop.name | escape }}" width="64" height="64">{% endif %}
    <div class="dl-mh__brand">Denti Luxe</div>
    <div class="dl-mh__tag">L’art du sourire</div>
  </div>
  <div class="dl-mf">
    <div class="dl-mf__promo"><span class="dl-mf__dot"></span> Offre de lancement · Paiement à la livraison</div>
    {% if dl_p %}<a class="dl-mf__btn" href="{{ dl_p.url }}">Commander — {{ dl_p.price | money }}</a>{% endif %}
    <div class="dl-mf__chips">
      <span class="dl-mf__chip">Paiement à la livraison</span>
      <span class="dl-mf__chip">Livraison 24–72h</span>
      <span class="dl-mf__chip">Satisfait ou remboursé</span>
    </div>
  </div>
</template>

<style>
  .header-drawer .menu-drawer__navigation{display:flex;flex-direction:column;}
  /* Liens plus travaillés */
  .header-drawer .menu-drawer__menu .menu-drawer__menu-item{
    font-size:1.45rem;font-weight:600;padding-top:18px;padding-bottom:18px;
    border-bottom:1px solid rgba(203,170,106,.16);transition:padding-left .2s ease,color .2s ease;
  }
  .header-drawer .menu-drawer__menu .menu-drawer__menu-item:hover,
  .header-drawer .menu-drawer__menu .menu-drawer__menu-item:focus{padding-left:8px;}
  .header-drawer .menu-drawer__menu > li:last-child .menu-drawer__menu-item{border-bottom:none;}

  /* Bloc marque (haut) */
  .dl-mh{display:flex;flex-direction:column;align-items:flex-start;gap:4px;padding:2px 2px 18px;margin-bottom:6px;border-bottom:1px solid rgba(203,170,106,.22);}
  .dl-mh__logo{width:60px;height:60px;object-fit:contain;filter:drop-shadow(0 8px 20px rgba(0,0,0,.45));margin-bottom:6px;}
  .dl-mh__brand{font-family:'Playfair Display',Georgia,serif;font-weight:800;font-size:1.5rem;color:#E6D09A;letter-spacing:.5px;}
  .dl-mh__tag{font-size:.66rem;letter-spacing:.34em;text-transform:uppercase;color:#9aa3b4;}

  /* Bloc CTA (bas) */
  .dl-mf{margin-top:auto;padding-top:20px;border-top:1px solid rgba(203,170,106,.22);display:flex;flex-direction:column;gap:12px;}
  .dl-mf__promo{display:inline-flex;align-items:center;gap:8px;font-size:.78rem;font-weight:700;color:#E6D09A;}
  .dl-mf__dot{width:7px;height:7px;border-radius:50%;background:#33BA86;box-shadow:0 0 0 4px rgba(51,186,134,.18);}
  .dl-mf__btn{display:flex;align-items:center;justify-content:center;background:linear-gradient(180deg,#E6D09A,#CBAA6A);color:#16110A;font-weight:800;font-size:1rem;padding:15px 18px;border-radius:14px;text-decoration:none;box-shadow:0 12px 30px rgba(203,170,106,.3);transition:transform .12s ease;}
  .dl-mf__btn:hover{transform:translateY(-2px);color:#16110A;}
  .dl-mf__chips{display:flex;flex-wrap:wrap;gap:6px;}
  .dl-mf__chip{font-size:.66rem;color:#9aa3b4;border:1px solid rgba(203,170,106,.25);border-radius:999px;padding:5px 9px;}
</style>

<script>
  (function(){
    var tpl=document.getElementById('dl-drawer-x');
    if(!tpl)return;
    function enhance(nav){
      if(!nav||nav.dataset.dlDone)return;
      nav.dataset.dlDone='1';
      var frag=tpl.content.cloneNode(true);
      var head=frag.querySelector('.dl-mh');
      var foot=frag.querySelector('.dl-mf');
      if(head)nav.insertBefore(head,nav.firstChild);
      if(foot)nav.appendChild(foot);
    }
    function scan(){
      var navs=document.querySelectorAll('header-drawer .menu-drawer__navigation');
      for(var i=0;i<navs.length;i++)enhance(navs[i]);
    }
    if(document.readyState!=='loading')scan();else document.addEventListener('DOMContentLoaded',scan);
    var mo=new MutationObserver(function(){scan();});
    mo.observe(document.documentElement,{childList:true,subtree:true});
  })();
</script>
